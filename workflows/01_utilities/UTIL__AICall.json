      "id": "4d10073c-d766-4595-94c4-7814f08fa4c5",
      "name": "OpenRouter Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [
        1536,
        208
      ],
      "credentials": {
        "openRouterApi": {
          "id": "bQsT6DYTg5L6QhOR",
          "name": "OpenRouter account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const original = $('Select Model').first().json;\nconst incomingData = $input.first().json;\n\nlet aiOutput = '';\nlet promptTokens = 0;\nlet completionTokens = 0;\nlet modelUsed = original.primary_model;\n\nif (original.is_embedding) {\n  aiOutput = incomingData; \n} else {\n  if (incomingData.text) {\n    aiOutput = incomingData.text;\n    promptTokens = incomingData.metadata?.usage?.prompt_tokens || 0;\n    completionTokens = incomingData.metadata?.usage?.completion_tokens || 0;\n  } else {\n    aiOutput = \"ERROR: \" + JSON.stringify(incomingData);\n  }\n}\n\nconst latencyMs = Date.now() - original.start_time;\n\nreturn {\n  json: {\n    ...original,\n    response: aiOutput,\n    model_used: modelUsed,\n    tokens_input: promptTokens,\n    tokens_output: completionTokens,\n    latency_ms: latencyMs,\n    cost_usd: 0.00,\n    workflow_name: \"UTIL__AICall\",\n    log_type: \"ai_call\",\n    action: original.is_embedding ? \"ai_embedding\" : \"ai_completion\",\n    input_payload: original.prompt\n  }\n};"
      },
      "id": "82eea919-2c20-4235-9a24-8c47f52005cf",
      "name": "Calculate Usage",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
