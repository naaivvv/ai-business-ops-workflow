    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst pref = item.model_preference || 'fast';\n\nlet primary_model = \"openrouter/free\";\nlet is_embedding = false;\n\nif (pref === 'embedding') {\n  primary_model = \"sentence-transformers/all-MiniLM-L6-v2\";\n  is_embedding = true;\n}\n\nreturn {\n  json: {\n    ...item,\n    primary_model,\n    is_embedding,\n    start_time: Date.now()\n  }\n};"
      },
      "id": "90d2a002-8e33-4a58-8be3-98cdb0dcad3d",
      "name": "Select Model",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        864,
        -80
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.is_embedding }}",
              "value2": true
            }
          ]
        }
      },
      "id": "fa64f4e1-ffdd-4068-9394-94a212cc262c",
      "name": "Is Embedding?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
