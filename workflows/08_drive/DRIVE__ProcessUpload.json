      "typeVersion": 1,
      "id": "89b533d1-93e5-472a-9db1-35b7ccff32bc"
    },
    {
      "parameters": {
        "content": "## DRIVE__ProcessUpload\n\nAutomatically processes general file uploads to Google Drive:\n\n1. **Monitor** - Watches specific Inbox/Upload folder for new files\n2. **Deduplicate** - Checks if file has already been processed\n3. **Download** - Retrieves file content from Google Drive\n4. **Extract** - Parses text from the file\n5. **Classify & Summarize** - Determines document type and generates summary via AI\n6. **Store** - Saves event details to Supabase events table\n7. **Notify** - Sends Slack notification to #general-uploads\n8. **Audit Log** - Logs workflow completion",
        "height": 450,
        "width": 1000,
        "color": 2
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        200,
        -100
      ],
      "typeVersion": 1,
      "id": "d04d701e-28ff-45b7-a367-bf019803b9b4",
      "name": "Sticky Note"
    }
  ],
