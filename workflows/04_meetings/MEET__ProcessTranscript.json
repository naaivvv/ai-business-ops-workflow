    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const fileName = $('Google Drive Trigger').item.json.name || '';\n  let text = '';\n\n  // Detect file type and extract text\n  if (item.binary && item.binary.data) {\n    if (fileName.endsWith('.docx')) {\n      // Use n8n's built-in binary parsing or assume binary data provides parsed text \n      text = Buffer.from(item.binary.data.data, 'base64').toString('utf8');\n    } else {\n      // For .txt, Google Docs (exported as text), .vtt, .srt\n      text = Buffer.from(item.binary.data.data, 'base64').toString('utf8');\n    }\n  } else {\n    text = item.json.content || item.json.text || '';\n  }\n\n  // Strip timestamps for subtitle files\n  if (fileName.endsWith('.vtt') || fileName.endsWith('.srt')) {\n    text = text.replace(/\\d{2}:\\d{2}:\\d{2}[.,]\\d{3}\\s*-->\\s*\\d{2}:\\d{2}:\\d{2}[.,]\\d{3}/g, '')\n               .replace(/^\\d+$/gm, '')\n               .replace(/\\n{3,}/g, '\\n\\n');\n  }\n\n  item.json.transcript_text = text;\n}\nreturn $input.all();"
      },
