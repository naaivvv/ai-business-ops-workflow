    {
      "parameters": {
        "jsCode": "const answer = $input.item.json.response;\nconst model_used = $input.item.json.model_used;\nconst formatContextNode = $('Format Context').item.json;\n\nreturn {\n  query: formatContextNode.query,\n  answer: answer,\n  sources: formatContextNode.sources,\n  model_used: model_used\n};"
      },
