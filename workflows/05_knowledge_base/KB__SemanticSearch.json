      },
      "id": "0d3a21fa-6592-4abd-b636-e1d96196a11f",
      "name": "Generate Answer",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        1568,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "return {\n  prompt: `Question: ${$json.query}\\n\\nContext from knowledge base:\\n${$json.context}\\n\\nAnswer the question using ONLY the provided context. If the context doesn't contain enough information to answer, say 'I don't have enough information to answer this question.' and suggest who to contact.`,\n  system_message: \"You are a knowledgeable assistant answering questions based on organizational documents. Only use information from the provided context. Cite your sources.\",\n  model_preference: \"fast\",\n  output_format: \"text\"\n};"
      },
      "id": "4e4bad21-7b18-4f5b-854c-e4a39eb78640",
      "name": "Prepare Answer Input",
      "type": "n8n-nodes-base.code",
