    {
      "parameters": {
        "content": "## Ingest Document\n\nMonitors a Google Drive folder for new documents. When a file is created:\n1. Deduplicates to prevent reprocessing\n2. Downloads and extracts text content\n3. Computes content hash to detect changes\n4. Checks if document already exists in Supabase\n5. If changed: deletes old embeddings, upserts document record\n6. Chunks text and generates embeddings\n7. Marks document as complete and logs to audit trail",
        "height": 480,
        "width": 2960,
        "color": 3
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -280,
        -144
      ],
      "id": "b4972602-30a9-465d-b398-bac493dfaeb0",
      "name": "Sticky Note1"
    }
