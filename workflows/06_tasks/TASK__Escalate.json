        "workflowInputs": "={{ {\n  \"channel\": `@${$('Escalate Each').item.json.manager_slack_id}`,\n  \"message\": $('Escalate Each').item.json.manager_message\n} }}"
      },
      "id": "task-escalate-notify-manager",
      "name": "Notify Manager",
      "type": "n8n-nodes-base.executeWorkflow",
