    },
    {
      "parameters": {
        "workflowId": "UTIL__SendSlackMessage",
        "mode": "each",
        "workflowInputs": "={{ {\n  \"channel\": \"#ops-alerts\",\n  \"message\": $('Escalate Each').item.json.ops_message\n} }}"
      },
      "id": "task-escalate-alert-ops",
      "name": "Alert Ops Channel",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        1760,
        -120
      ]
    },
    {
      "parameters": {
        "jsCode": "let prepared = [];\ntry {\n  prepared = $('Prepare Escalation Details').all().map(item => item.json).filter(task => task && task.id);\n} catch (e) {\n  prepared = [];\n}\n\nreturn [{\n  json: {\n    audit_payload: {\n      escalated_count: prepared.length,\n      task_ids: prepared.map(task => task.id),\n      manager_notifications: prepared.filter(task => task.manager_slack_id).length,\n      ops_alerts: prepared.length\n    }\n  }\n}];"
      },
      "id": "task-escalate-build-audit-payload",
      "name": "Build Audit Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
