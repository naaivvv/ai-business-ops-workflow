            },
            {
              "fieldId": "priority",
              "fieldValue": "critical"
            },
            {
              "fieldId": "updated_at",
              "fieldValue": "={{ new Date().toISOString() }}"
            }
          ]
        }
      },
      "id": "task-escalate-mark-escalated",
