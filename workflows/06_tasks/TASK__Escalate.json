      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT t.*, u.name as assignee_name, u.email as assignee_email,\n       m.slack_user_id as manager_slack_id, m.name as manager_name\nFROM tasks t\nLEFT JOIN users u ON t.assigned_to = u.id\nLEFT JOIN users m ON u.manager_id = m.id\nWHERE t.status = 'open'\nAND t.deadline < NOW() - INTERVAL '24 hours'\nAND t.escalated_at IS NULL"
      },
      "id": "task-escalate-query-overdue-unescalated",
      "name": "Query Overdue Unescalated",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        220,
        0
      ],
      "alwaysOutputData": true,
      "credentials": {
        "supabaseApi": {
          "id": "goFlWTHKylYQ7NES",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "query-returned-task-row",
              "leftValue": "={{ $json.id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "task-escalate-any-tasks",
      "name": "Any Tasks to Escalate?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const now = Date.now();\n\nreturn $input.all()\n  .filter(item => item.json && item.json.id)\n  .map(item => {\n    const task = item.json;\n    const deadlineTime = task.deadline ? new Date(task.deadline).getTime() : now;\n    const hoursOverdue = Math.max(0, Math.floor((now - deadlineTime) / (1000 * 60 * 60)));\n    const assigneeName = task.assignee_name || task.assignee_email || 'Unassigned';\n    const deadline = task.deadline || 'No deadline';\n\n    return {\n      json: {\n        ...task,\n        hours_overdue: hoursOverdue,\n        manager_message: `🚨 *Task Escalation*\\n*Task:* ${task.title || 'Untitled task'}\\n*Assigned to:* ${assigneeName}\\n*Deadline:* ${deadline} (overdue by ${hoursOverdue} hours)\\n*Priority:* Upgraded to CRITICAL`,\n        ops_message: `🚨 *Task Escalated*\\n*Task:* ${task.title || 'Untitled task'}\\n*Assigned to:* ${assigneeName}\\n*Manager:* ${task.manager_name || 'No manager on file'}\\n*Deadline:* ${deadline}\\n*Overdue:* ${hoursOverdue} hours\\n*Priority:* Upgraded to CRITICAL`\n      }\n    };\n  });"
      },
      "id": "task-escalate-prepare-details",
      "name": "Prepare Escalation Details",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        -120
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "task-escalate-loop",
      "name": "Escalate Each",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [
        880,
        -120
      ]
    },
    {
      "parameters": {
        "operation": "update",
