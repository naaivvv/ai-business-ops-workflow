        "workflowInputs": "={{ {\n  \"workflow_name\": \"TASK__Escalate\",\n  \"execution_id\": $execution.id,\n  \"log_type\": \"action\",\n  \"action\": \"tasks_escalated\",\n  \"input_payload\": {\n    \"schedule\": \"0 * * * *\",\n    \"overdue_threshold_hours\": 24\n  },\n  \"output_payload\": $json.audit_payload,\n  \"status\": \"success\"\n} }}"
      },
      "id": "task-escalate-audit-log",
      "name": "Audit Log",
      "type": "n8n-nodes-base.executeWorkflow",
