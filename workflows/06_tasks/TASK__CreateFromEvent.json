      "parameters": {
        "workflowId": "UTIL__SendSlackMessage",
        "mode": "each",
        "workflowInputs": "={{ {\n  \"channel\": `@${$('Prepare Task Payload').first().json.slack_user_id}`,\n  \"message\": `📋 *New Task Assigned*\\n*Title:* ${$('Prepare Task Payload').first().json.title}\\n*Priority:* ${$('Prepare Task Payload').first().json.priority}\\n*Deadline:* ${$('Prepare Task Payload').first().json.deadline || 'No deadline'}\\n*Description:* ${$('Prepare Task Payload').first().json.description || 'No description provided'}`\n} }}"
      },
