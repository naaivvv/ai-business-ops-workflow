    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nif (!data.title) {\n  throw new Error('Missing required field: title');\n}\n\nconst validPriorities = ['critical', 'high', 'medium', 'low'];\nconst priority = data.priority || 'medium';\nif (!validPriorities.includes(priority)) {\n  throw new Error(`Invalid priority: \"${priority}\". Must be one of: ${validPriorities.join(', ')}`);\n}\n\nreturn [{\n  json: {\n    title: data.title,\n    description: data.description || null,\n    assigned_to: data.assigned_to || null,\n    priority,\n    deadline: data.deadline || null,\n    source_event_id: data.source_event_id || null\n  }\n}];"
      },
      "id": "task-create-validate",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "users",
        "returnAll": false,
        "limit": 1,
        "filterType": "string",
        "filterString": "email=eq.{{ $json.assigned_to }}"
      },
      "id": "task-create-resolve-user",
      "name": "Resolve User",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        440,
        0
      ],
      "alwaysOutputData": true,
      "credentials": {
        "supabaseApi": {
          "id": "goFlWTHKylYQ7NES",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $('Validate Input').first().json;\nconst resolvedUser = $input.first().json || {};\n\nconst assignedToUuid = resolvedUser.id || null;\nconst slackUserId = resolvedUser.slack_user_id || null;\n\nreturn [{\n  json: {\n    title: input.title,\n    description: input.description,\n    assigned_to: assignedToUuid,\n    priority: input.priority,\n    deadline: input.deadline,\n    source_event_id: input.source_event_id,\n    assignee_email: input.assigned_to,\n    assignee_name: resolvedUser.name || null,\n    slack_user_id: slackUserId\n  }\n}];"
      },
      "id": "task-create-prepare-payload",
      "name": "Prepare Task Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        0
      ]
    },
    {
