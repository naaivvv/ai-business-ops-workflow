        -120
      ]
    },
    {
      "parameters": {
        "workflowId": "UTIL__WriteAuditLog",
        "mode": "each",
        "workflowInputs": "={{ {\n  \"workflow_name\": \"TASK__CreateFromEvent\",\n  \"execution_id\": $execution.id,\n  \"log_type\": \"action\",\n  \"action\": \"task_created\",\n  \"input_payload\": $('Validate Input').first().json,\n  \"output_payload\": {\n    \"task_id\": $('Insert Task').first().json.id,\n    \"assigned_to\": $('Prepare Task Payload').first().json.assigned_to,\n    \"slack_notified\": Boolean($('Prepare Task Payload').first().json.slack_user_id)\n  },\n  \"status\": \"success\"\n} }}"
      },
      "id": "task-create-audit-log",
      "name": "Audit Log",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        1540,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const task = $('Insert Task').first().json;\nconst payload = $('Prepare Task Payload').first().json;\n\nreturn [{\n  json: {\n    success: true,\n    task_id: task.id || null,\n    assigned_to: payload.assigned_to,\n    assignee_email: payload.assignee_email,\n    slack_notified: Boolean(payload.slack_user_id)\n  }\n}];"
      },
